---

---

<section class="section contact" id="contact">
  <div class="contact-glow" aria-hidden="true"></div>
  <div class="container contact-inner reveal">
    <p class="eyebrow">Contact</p>
    <h2 class="contact-title">Let's build.</h2>
    <p class="contact-lede">
      Tell us what you're trying to make possible. We'll reply with a point of view — and if
      we're not the right fit, we'll say so.
    </p>
    <div class="contact-actions">
      <a href="mailto:contact@siliconsteelsoftware.com" class="btn btn-primary">
        contact@siliconsteelsoftware.com
      </a>
      <a
        href="https://www.linkedin.com/company/silicon-steel-software"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-ghost"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          />
        </svg>
        LinkedIn
      </a>
    </div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    overflow: hidden;
  }

  .contact-glow {
    position: absolute;
    bottom: -45%;
    left: 50%;
    width: 64rem;
    height: 32rem;
    transform: translateX(-50%);
    background:
      radial-gradient(ellipse 60% 80% at 35% 50%, rgba(58, 141, 255, 0.4), transparent 65%),
      radial-gradient(ellipse 60% 80% at 70% 50%, rgba(167, 139, 250, 0.32), transparent 65%);
    filter: blur(56px);
    pointer-events: none;
  }

  .contact-inner {
    position: relative;
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.5rem;
  }

  .contact-title {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    background: linear-gradient(95deg, #f6f8ff 20%, #6fb0ff 60%, #22d3ee 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .contact-lede {
    max-width: 36rem;
    color: var(--text-muted);
    font-size: 1.125rem;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
</style>
