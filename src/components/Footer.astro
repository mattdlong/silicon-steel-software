---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <img class="footer-logo" src="/logo-light.svg" alt="Silicon Steel Software" width="140" height="60" />
    <p class="footer-copy">&copy; {year} Silicon Steel Software. All rights reserved.</p>
    <a
      href="https://www.linkedin.com/company/silicon-steel-software"
      target="_blank"
      rel="noopener noreferrer"
      class="footer-social"
      aria-label="Silicon Steel Software on LinkedIn"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        />
      </svg>
    </a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding-block: 2.5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .footer-logo {
    height: 2.25rem;
    width: auto;
    opacity: 0.85;
  }

  .footer-copy {
    color: var(--text-faint);
    font-size: 0.875rem;
  }

  .footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.5rem;
    color: var(--text-muted);
    transition: color 200ms var(--ease);
  }

  .footer-social:hover {
    color: var(--accent-light);
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
