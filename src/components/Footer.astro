---
const year = new Date().getFullYear();
const links = [
  { href: '#capabilities', label: 'Capabilities' },
  { href: '#approach', label: 'Approach' },
  { href: '#principles', label: 'Principles' },
  { href: '#contact', label: 'Contact' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img class="footer-logo" src="/logo-light.svg" alt="Silicon Steel Software" width="140" height="60" />
        <p class="footer-tagline">
          AI-native consultancy. Frontier AI, forged into production.
        </p>
      </div>

      <nav class="footer-col" aria-label="Footer">
        <p class="footer-heading">Site</p>
        {links.map(({ href, label }) => <a href={href} class="footer-link">{label}</a>)}
      </nav>

      <div class="footer-col">
        <p class="footer-heading">Get in touch</p>
        <a href="mailto:contact@siliconsteelsoftware.com" class="footer-link">
          contact@siliconsteelsoftware.com
        </a>
        <a
          href="https://www.linkedin.com/company/silicon-steel-software"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <div class="footer-bar">
      <p class="footer-copy">&copy; {year} Silicon Steel Software. All rights reserved.</p>
      <p class="footer-meta">Designed &amp; built in-house — with our own AI agents on the team.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--screen-line);
    padding-block: 3.5rem 2rem;
    background: var(--screen);
    color: var(--screen-text);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 2.5rem;
  }

  .footer-brand {
    display: grid;
    gap: 1rem;
    align-content: start;
    justify-items: start;
  }

  .footer-logo {
    height: 2.25rem;
    width: auto;
    opacity: 0.9;
  }

  .footer-tagline {
    color: var(--screen-muted);
    font-size: 0.875rem;
    max-width: 18rem;
  }

  .footer-col {
    display: grid;
    gap: 0.625rem;
    align-content: start;
    justify-items: start;
  }

  .footer-heading {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--screen-muted);
    margin-bottom: 0.375rem;
  }

  .footer-link {
    color: var(--screen-muted);
    font-size: 0.9375rem;
    transition: color 200ms var(--ease);
  }

  .footer-link:hover {
    color: var(--accent);
  }

  .footer-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid var(--screen-line);
  }

  .footer-copy,
  .footer-meta {
    color: var(--screen-muted);
    font-size: 0.8125rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-bar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
