---
const terminalLines = [
  { prompt: true, text: 'sss agent deploy support-triage --env prod' },
  { cls: 'dim', text: 'resolving tools ......... crm, kb-search, escalate' },
  { cls: 'dim', text: 'wiring guardrails ....... pii-filter, policy-check' },
  { cls: 'ok', text: 'eval suite ............. 312/312 passed (p95 1.2s)' },
  { cls: 'ok', text: 'canary 5% .............. CSAT +18% vs control' },
  { cls: 'accent', text: '▸ promoted to 100% — live' },
];
---

<section class="hero" id="top">
  <canvas class="hero-field" id="hero-field" aria-hidden="true"></canvas>
  <div class="hero-vignette" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">AI-native consultancy</p>
      <h1 class="hero-title">
        Frontier AI,<br />
        <span class="hero-title-accent">forged into production.</span>
      </h1>
      <p class="hero-lede">
        We design, build, and ship agentic systems, LLM products, and the platforms beneath
        them. Senior engineers, measurable results — in weeks, not quarters.
      </p>
      <div class="hero-actions">
        <a href="mailto:contact@siliconsteelsoftware.com" class="btn btn-primary">
          Start a conversation
        </a>
        <a href="#capabilities" class="btn btn-ghost">Explore capabilities</a>
      </div>
    </div>

    <div class="terminal panel" aria-hidden="true">
      <div class="terminal-bar">
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-name">agent-run — prod</span>
      </div>
      <div class="terminal-body">
        {
          terminalLines.map(({ prompt, cls, text }, i) => (
            <p class={`terminal-line ${cls ?? ''}`} style={`--i: ${i}`}>
              {prompt && <span class="terminal-prompt">❯</span>}
              {text}
            </p>
          ))
        }
        <p class="terminal-line caret" style={`--i: ${terminalLines.length}`}>
          <span class="terminal-prompt">❯</span>
          <span class="terminal-caret"></span>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100svh;
    padding-top: var(--nav-height);
    overflow: hidden;
  }

  .hero-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 28% 45%, rgba(3, 5, 9, 0.82), transparent 70%),
      linear-gradient(180deg, rgba(3, 5, 9, 0.5), transparent 30%, transparent 75%, var(--bg));
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 4rem;
    padding-block: 6rem;
    width: 100%;
  }

  .hero-copy {
    display: grid;
    gap: 1.75rem;
    justify-items: start;
  }

  .hero-title {
    font-size: clamp(2.75rem, 6.5vw, 4.75rem);
    font-weight: 700;
  }

  .hero-title-accent {
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-lede {
    max-width: 34rem;
    font-size: clamp(1.0625rem, 1.8vw, 1.1875rem);
    color: var(--text-muted);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* Terminal */
  .terminal {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.6), 0 0 60px rgba(58, 141, 255, 0.12);
    backdrop-filter: blur(4px);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .terminal-dot {
    width: 0.625rem;
    height: 0.625rem;
    border-radius: 50%;
    background: var(--border-strong);
  }

  .terminal-name {
    margin-left: 0.5rem;
    color: var(--text-faint);
    font-size: 0.75rem;
  }

  .terminal-body {
    padding: 1.25rem 1.25rem 1.5rem;
    display: grid;
    gap: 0.55rem;
  }

  .terminal-line {
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    opacity: 0;
    animation: line-in 300ms var(--ease) forwards;
    animation-delay: calc(0.5s + var(--i) * 0.55s);
  }

  .terminal-line.dim {
    color: var(--text-faint);
  }

  .terminal-line.ok {
    color: #54e6a4;
  }

  .terminal-line.accent {
    color: var(--cyan);
    text-shadow: 0 0 18px var(--glow-cyan);
  }

  .terminal-prompt {
    color: var(--electric);
    margin-right: 0.5rem;
  }

  .terminal-caret {
    display: inline-block;
    width: 0.55em;
    height: 1.05em;
    vertical-align: text-bottom;
    background: var(--cyan);
    animation: caret-blink 1.1s steps(1) infinite;
  }

  @keyframes line-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @keyframes caret-blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-line {
      opacity: 1;
      animation: none;
    }
  }

  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 3rem;
      padding-block: 5rem;
    }

    .terminal {
      max-width: 34rem;
    }
  }

  @media (max-width: 480px) {
    .terminal {
      font-size: 0.6875rem;
    }
  }
</style>

<script>
  // Neural field: drifting particles linked by proximity edges, blue/cyan.
  const canvas = document.getElementById('hero-field') as HTMLCanvasElement | null;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0;
    let h = 0;
    let raf = 0;

    type P = { x: number; y: number; vx: number; vy: number; r: number; hue: number };
    let particles: P[] = [];

    const resize = () => {
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(110, Math.floor((w * h) / 16000));
      particles = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.35,
        vy: (Math.random() - 0.5) * 0.35,
        r: 1 + Math.random() * 1.6,
        hue: 205 + Math.random() * 25,
      }));
    };

    const LINK = 130;

    const draw = () => {
      ctx.clearRect(0, 0, w, h);

      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < -20) p.x = w + 20;
        if (p.x > w + 20) p.x = -20;
        if (p.y < -20) p.y = h + 20;
        if (p.y > h + 20) p.y = -20;
      }

      for (let i = 0; i < particles.length; i++) {
        const a = particles[i];
        for (let j = i + 1; j < particles.length; j++) {
          const b = particles[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < LINK * LINK) {
            const alpha = (1 - Math.sqrt(d2) / LINK) * 0.32;
            ctx.strokeStyle = `hsla(212, 100%, 64%, ${alpha})`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      for (const p of particles) {
        ctx.fillStyle = `hsla(${p.hue}, 100%, 70%, 0.9)`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
    };

    const loop = () => {
      draw();
      raf = requestAnimationFrame(loop);
    };

    resize();
    window.addEventListener('resize', resize);

    if (reduced) {
      draw(); // static frame
    } else {
      // Pause the loop when the hero is offscreen.
      const observer = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          if (!raf) raf = requestAnimationFrame(loop);
        } else {
          cancelAnimationFrame(raf);
          raf = 0;
        }
      });
      observer.observe(canvas);
    }
  }
</script>
