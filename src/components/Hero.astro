---

---

<section class="hero" id="top">
  <div class="container hero-inner">
    <p class="eyebrow">AI-native consultancy</p>
    <h1 class="hero-title">
      Frontier AI, <em>forged</em> into production.
    </h1>
    <p class="hero-lede">
      Silicon Steel Software designs, builds, and ships agentic systems, LLM products, and the
      platforms beneath them. Senior engineers, measurable results — in weeks, not quarters.
    </p>
    <div class="hero-actions">
      <a href="mailto:contact@siliconsteelsoftware.com" class="btn btn-primary">
        Start a conversation
      </a>
      <a href="#capabilities" class="text-link">
        Explore capabilities
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
  <div class="container">
    <hr class="section-rule hero-rule" />
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--nav-height) + clamp(4rem, 12vh, 9rem));
  }

  .hero-inner {
    display: grid;
    gap: 2.25rem;
    padding-bottom: clamp(4rem, 10vh, 7rem);
  }

  .hero-title {
    max-width: 18ch;
    font-size: clamp(3rem, 8.5vw, 6.5rem);
    animation: hero-rise 700ms var(--ease) both;
  }

  .hero-title em {
    font-style: italic;
    font-weight: 400;
  }

  .hero-lede {
    max-width: 38rem;
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    color: var(--ink-soft);
    animation: hero-rise 700ms 100ms var(--ease) both;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.75rem;
    animation: hero-rise 700ms 200ms var(--ease) both;
  }

  .eyebrow {
    animation: hero-rise 700ms var(--ease) both;
  }

  .hero-rule {
    border-top-color: var(--rule-dark);
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
