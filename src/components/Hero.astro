---

<section class="hero" id="top">
  <div class="hero-backdrop" aria-hidden="true">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
  </div>

  <div class="container hero-inner">
    <p class="eyebrow">AI-native consultancy</p>
    <h1 class="hero-title">
      Frontier AI,<br />
      <span class="hero-title-accent">forged into production.</span>
    </h1>
    <p class="hero-lede">
      Silicon Steel Software designs, builds, and ships agentic systems, LLM products, and the
      platforms beneath them. Senior engineers, measurable results — in weeks, not quarters.
    </p>
    <div class="hero-actions">
      <a href="mailto:contact@siliconsteelsoftware.com" class="btn btn-primary">
        Start a conversation
      </a>
      <a href="#capabilities" class="btn btn-ghost">Explore capabilities</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100svh;
    padding-top: var(--nav-height);
    overflow: hidden;
  }

  .hero-backdrop {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse 90% 70% at 50% 40%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 70% at 50% 40%, black 30%, transparent 75%);
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    width: 60rem;
    height: 36rem;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, var(--accent-glow), transparent 65%);
    opacity: 0.45;
    filter: blur(40px);
  }

  .hero-inner {
    position: relative;
    display: grid;
    gap: 2rem;
    padding-block: 6rem;
    max-width: var(--container);
  }

  .hero-title {
    font-size: clamp(2.75rem, 8vw, 5.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    animation: hero-rise 800ms var(--ease) both;
  }

  .hero-title-accent {
    background: linear-gradient(100deg, var(--accent) 0%, #7cc1ff 60%, #b8dcff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-lede {
    max-width: 40rem;
    font-size: clamp(1.125rem, 2vw, 1.3125rem);
    color: var(--text-muted);
    animation: hero-rise 800ms 120ms var(--ease) both;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    animation: hero-rise 800ms 240ms var(--ease) both;
  }

  .eyebrow {
    animation: hero-rise 800ms var(--ease) both;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
