---
const principles = [
  {
    title: 'Senior engineers only',
    description:
      'The people you meet are the people who build. No leverage pyramids, no hand-offs to a bench you never interviewed.',
  },
  {
    title: 'Production-first',
    description:
      'Prototypes prove value; production captures it. We design for the second day one — deployment, monitoring, and cost from the start.',
  },
  {
    title: 'Measured, not vibes',
    description:
      'Every system ships with an evaluation harness. If quality moves, you see it in numbers before your customers feel it.',
  },
  {
    title: 'Built to hand over',
    description:
      'We transfer capability, not dependency. Documentation, pairing, and tooling that leave your team stronger than we found it.',
  },
];
---

<section class="section" id="principles">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">03 — Principles</p>
      <h2 class="section-title">How we work.</h2>
      <p class="section-lede">
        Silicon for intelligence, steel for discipline. The name is the operating model.
      </p>
    </div>

    <div class="principles">
      {
        principles.map(({ title, description }) => (
          <div class="principle reveal">
            <h3 class="principle-title">{title}</h3>
            <p class="principle-description">{description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .principles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem 4rem;
  }

  .principle {
    display: grid;
    gap: 0.625rem;
    align-content: start;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule);
  }

  .principle-title {
    font-size: 1.5rem;
  }

  .principle-description {
    color: var(--ink-soft);
    max-width: 32rem;
  }

  @media (max-width: 768px) {
    .principles {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
