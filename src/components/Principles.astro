---
const principles = [
  {
    index: '01',
    title: 'Senior engineers only',
    description:
      'The people you meet are the people who build. No leverage pyramids, no hand-offs to a bench you never interviewed.',
  },
  {
    index: '02',
    title: 'Production-first',
    description:
      'Prototypes prove value; production captures it. We design for the second day one — deployment, monitoring, and cost from the start.',
  },
  {
    index: '03',
    title: 'Measured, not vibes',
    description:
      'Every system ships with an evaluation harness. If quality moves, you see it in numbers before your customers feel it.',
  },
  {
    index: '04',
    title: 'Built to hand over',
    description:
      'We transfer capability, not dependency. Documentation, pairing, and tooling that leave your team stronger than we found it.',
  },
];
---

<section class="section" id="principles">
  <div class="container">
    <div class="section-header reveal">
      <p class="eyebrow">Principles</p>
      <h2 class="section-title">How we work.</h2>
      <p class="section-lede">
        Silicon for intelligence, steel for discipline. The name is the operating model.
      </p>
    </div>

    <div class="principles">
      {
        principles.map(({ index, title, description }) => (
          <div class="principle panel panel-hover reveal">
            <span class="principle-index" aria-hidden="true">{index}</span>
            <h3 class="card-title">{title}</h3>
            <p class="principle-description">{description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .principles {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .principle {
    position: relative;
    display: grid;
    gap: 0.625rem;
    align-content: start;
    padding: 2rem;
    overflow: hidden;
  }

  .principle:nth-child(2),
  .principle:nth-child(4) {
    --reveal-delay: 80ms;
  }

  .principle-index {
    position: absolute;
    top: -1.5rem;
    right: 0.5rem;
    font-family: var(--font-display);
    font-size: 7rem;
    font-weight: 700;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(140, 170, 255, 0.16);
    pointer-events: none;
  }

  .principle-description {
    color: var(--text-muted);
    font-size: 0.9375rem;
    max-width: 30rem;
  }

  @media (max-width: 768px) {
    .principles {
      grid-template-columns: 1fr;
    }
  }
</style>
